{
    "appId": "com.lh_unc_pardina_lucas.scmatu_software", 
    "files": [
        "dist-electron",
        "dist-react"
    ],
    "extraResources": [
        {
            "from": "src/electron/backend",
            "to": "backend",
            "filter": ["**/*"]
        }
    ],
    "icon": "./desktopIcon.png", 
    "mac": {
        "target": "dmg"
    },
    "linux": {
        "target": [
            "AppImage",
            "deb"
        ],
        "category": "Utility"
    },
    "win": {
        "target": [
            "portable",
            "nsis"
        ]
    },
    "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": true,
        "shortcutName": "SCMATU-Software",
        "allowElevation": true,
        "runAfterFinish": true
    }
}