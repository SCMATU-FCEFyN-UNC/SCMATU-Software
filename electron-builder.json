{
    "appId": "com.lh_unc_pardina_lucas.ultrasonic-amplifier-control", 
    "files": [
        "dist-electron",
        "dist-react"
    ],
    "extraResources": [
        {
            "from": "src/electron/backend",
            "to": "backend",
            "filter": ["*.exe"]
        },
        {
            "from": "dist-electron",
            "to": "dist-electron",
            "filter": ["preload.cjs"]
        }
    ],
    "icon": "./desktopIcon.png", 
    "mac": {
        "target": "dmg"
    },
    "linux": {
        "target": [
            "AppImage",
            "deb"
        ],
        "category": "Utility"
    },
    "win": {
        "target": [
            "portable",
            "nsis"
        ]
    },
    "portable": {
        "artifactName": "ultrasonic-amplifier-control-win-${arch}.portable.${ext}"
    },
    "nsis": {
        "oneClick": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": true,
        "shortcutName": "Ultrasonic Amplifier Control",
        "allowElevation": true,
        "runAfterFinish": true,
        "artifactName": "ultrasonic-amplifier-control-win-${arch}.installer.${ext}"
    }
}